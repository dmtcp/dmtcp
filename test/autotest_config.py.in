USE_TEST_SUITE="@USE_TEST_SUITE@"
USE_M32=@M32@
USE_MULTILIB=@MULTILIB@
DEBUG="@DEBUG@"
ARM_HOST="@ARM_HOST@"
AARCH64_HOST="@AARCH64_HOST@"

# We may be running a user's python, but we should only test with canonical one
HAS_PS="@HAS_PS@"
HAS_PYTHON="@HAS_PYTHON@"
HAS_PYTHON3="@HAS_PYTHON3@"
HAS_READLINE="@HAS_READLINE@"
HAS_SELINUX="@HAS_SELINUX@"
HAS_VIM="@HAS_VIM@"
VIM="@VIM@"
HAS_STRACE="@HAS_STRACE@"
HAS_GDB="@HAS_GDB@"
HAS_JAVA="@HAS_JAVA@"
HAS_JAVAC="@HAS_JAVAC@"
HAS_SSH_LOCALHOST="@HAS_SSH_LOCALHOST@"
HAS_CMA="@HAS_CMA@"
HAS_EPOLL_CREATE1="@HAS_EPOLL_CREATE1@"
HAS_SYS_MQ_OPEN="@HAS_SYS_MQ_OPEN@"
HAS_CILK="@HAS_CILK@"
HAS_GCL="@HAS_GCL@"
GCL="@GCL@"
HAS_MATLAB="@HAS_MATLAB@"
MATLAB="@MATLAB@"
TEST_POSIX_MQ="@TEST_POSIX_MQ@"

OPENMP_CFLAGS="@OPENMP_CFLAGS@"
if OPENMP_CFLAGS != "":
  HAS_OPENMP="yes"
else:
  HAS_OPENMP="no"

HAS_MPICH="@HAS_MPICH@"
MPICH_PATH="@MPICH_PATH@"

# USES_OPENMPI_ORTED="@USES_OPENMPI_ORTED@"
HAS_OPENMPI="@HAS_OPENMPI@"
OPENMPI_MPICC="@OPENMPI_MPICC@"
OPENMPI_MPIRUN="@OPENMPI_MPIRUN@"

if USE_M32:
  HAS_READLINE="no"
  HAS_MPICH="no"
  HAS_OPENMPI="no"
  HAS_CILK="no"
